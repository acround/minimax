{
    "name": "your-vendor/minimax-php",
    "description": "PHP library for Minimax.rs API",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Your Name",
            "email": "you@example.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "YourVendor\\Minimax\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YourVendor\\Minimax\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
