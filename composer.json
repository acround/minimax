{
    "name": "acround/minimax-php",
    "description": "PHP library for Minimax.rs API",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "ACRound",
            "email": "you@example.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "guzzlehttp/guzzle": "^7.0",
        "yiisoft/yii2": "~2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "acround\\Minimax\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "acround\\Minimax\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
